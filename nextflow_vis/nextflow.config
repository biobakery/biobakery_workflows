/*
 * bioBakery Visualization Workflow — Nextflow configuration
 *
 * Profiles
 * --------
 *  standard   (default) local execution, no container
 *  docker                         local + Docker
 *  singularity                    local + Singularity (HPC-friendly)
 *  conda                          local + Conda
 *  slurm                          SLURM HPC + Singularity
 *  pbs                            PBS/Torque HPC + Singularity
 *  lsf                            IBM LSF HPC + Singularity
 *  sge                            Sun Grid Engine HPC + Singularity
 *  aws                            AWS Batch + Docker
 *  gcp                            Google Cloud Batch + Docker
 *
 * Combine execution + container profiles as needed, e.g.:
 *   -profile slurm,singularity
 *   -profile aws,docker
 */

// ============================================================================
// Global defaults
// ============================================================================
manifest {
    name            = 'biobakery/vis-nextflow'
    author          = 'bioBakery workflows development team'
    description     = 'Nextflow port of the bioBakery AnADAMA2 visualization workflow'
    version         = '4.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// Default container image (overridden per profile)
params.container = 'biobakery/workflows:latest'

// ============================================================================
// Base process resource defaults
// ============================================================================
includeConfig 'conf/base.config'

// ============================================================================
// Profiles
// ============================================================================
profiles {

    // ── Local (no container) ─────────────────────────────────────────────────
    standard {
        process.executor = 'local'
    }

    // ── Docker (local) ───────────────────────────────────────────────────────
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false

        process {
            container = params.container
        }
    }

    // ── Singularity (local or HPC) ───────────────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false

        process {
            container = params.container
        }
    }

    // ── Conda ────────────────────────────────────────────────────────────────
    conda {
        conda.enabled          = true
        process {
            conda = "${projectDir}/environments/conda.yml"
        }
    }

    // ── SLURM HPC ────────────────────────────────────────────────────────────
    slurm {
        includeConfig 'conf/slurm.config'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process {
            container = params.container
        }
    }

    // ── PBS / Torque HPC ─────────────────────────────────────────────────────
    pbs {
        includeConfig 'conf/pbs.config'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process {
            container = params.container
        }
    }

    // ── IBM LSF HPC ──────────────────────────────────────────────────────────
    lsf {
        includeConfig 'conf/lsf.config'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process {
            container = params.container
        }
    }

    // ── Sun Grid Engine ──────────────────────────────────────────────────────
    sge {
        process.executor       = 'sge'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process {
            container    = params.container
            penv         = 'smp'
            clusterOptions = { "-l h_vmem=${task.memory.toGiga()}G" }
        }
    }

    // ── AWS Batch ────────────────────────────────────────────────────────────
    aws {
        includeConfig 'conf/aws.config'
        docker.enabled      = true
        singularity.enabled = false
        process {
            container = params.container
        }
    }

    // ── Google Cloud Batch ───────────────────────────────────────────────────
    gcp {
        includeConfig 'conf/gcp.config'
        docker.enabled      = true
        singularity.enabled = false
        process {
            container = params.container
        }
    }

    // ── Test (CI) ────────────────────────────────────────────────────────────
    test {
        params.input  = "${projectDir}/test_data/example_input"
        params.output = "test_output"
        params.format = "pdf"
    }
}

// ============================================================================
// Execution report / trace / timeline
// ============================================================================
timeline {
    enabled = true
    file    = "${params.output}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.output}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.output}/pipeline_info/trace.tsv"
    overwrite = true
    fields    = 'task_id,hash,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

// ============================================================================
// Cleanup work dir on successful completion (optional, enable if desired)
// ============================================================================
// cleanup = true
