/*
 * SLURM HPC configuration
 *
 * Adjust queue/partition and clusterOptions to match your cluster.
 * Common partition names: main, short, long, highmem, cpu
 *
 * Override on the command line:
 *   nextflow run main.nf -profile slurm,singularity \
 *       --slurm_queue highmem
 */

params.slurm_queue        = 'main'
params.slurm_queue_size   = 50    // max concurrent jobs
params.slurm_time         = '8:00:00'
params.slurm_account      = ''    // set to your HPC account if required

process {
    executor       = 'slurm'
    queue          = params.slurm_queue
    queueSize      = params.slurm_queue_size
    submitRateLimit = '10 sec'

    withName: GENERATE_VIS_REPORT {
        cpus   = 4
        memory = '32 GB'
        time   = params.slurm_time

        clusterOptions = {
            def account_opt = params.slurm_account ? "--account=${params.slurm_account}" : ""
            "--nodes=1 --ntasks=1 --cpus-per-task=${task.cpus} ${account_opt}"
        }
    }
}

// Enable scratch directory on SLURM nodes (improves I/O performance)
// Uncomment and set to your cluster's scratch path:
// process.scratch = '/tmp'
