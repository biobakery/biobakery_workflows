/*
 * Google Cloud Batch configuration
 *
 * Prerequisites:
 *   1. A GCP project with Cloud Batch API enabled.
 *   2. A GCS bucket for work directory and I/O.
 *   3. A service account with Batch Job Editor + Storage Object Admin roles.
 *
 * Authenticate before running:
 *   gcloud auth application-default login
 *   # or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
 *
 * Override params on the command line:
 *   nextflow run main.nf -profile gcp \
 *       --gcp_project my-project \
 *       --gcp_region us-central1 \
 *       -work-dir gs://my-bucket/nextflow-work
 */

params.gcp_project     = ''         // REQUIRED: your GCP project ID
params.gcp_region      = 'us-central1'
params.gcp_network     = 'default'
params.gcp_subnetwork  = ''

if (!params.gcp_project) {
    log.error "ERROR: --gcp_project is required when using the 'gcp' profile."
    System.exit(1)
}

google {
    project = params.gcp_project
    region  = params.gcp_region
    batch {
        spot     = false          // set true to use Spot (preemptible) VMs
        network  = params.gcp_network
        subnetwork = params.gcp_subnetwork ?: null
    }
}

process {
    executor = 'google-batch'

    withName: GENERATE_VIS_REPORT {
        cpus         = 4
        memory       = '32 GB'
        time         = '8 h'
        machineType  = 'n2-standard-4'   // override with highmem if needed
    }
}
