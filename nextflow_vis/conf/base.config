/*
 * Base resource configuration for all processes.
 *
 * The GENERATE_VIS_REPORT process runs:
 *   - alpha_diversity.R  (R/vegan, single-threaded)
 *   - Pweave templates   (matplotlib heatmaps, PCoA, barplots)
 *   - Pandoc → LaTeX → PDF (can be memory-intensive for large cohorts)
 *   - hclust2            (hierarchical clustering)
 *
 * Peak memory scales with: number of samples × number of features.
 * Defaults here are conservative; increase for large studies (>200 samples).
 */

process {
    // Defaults applied to every process unless overridden below
    cpus   = 4
    memory = '16 GB'
    time   = '4 h'

    // GENERATE_VIS_REPORT runs the full pipeline sequentially inside anadama2.
    withName: GENERATE_VIS_REPORT {
        cpus   = 4
        memory = '32 GB'
        time   = '8 h'
    }

    // Retry with progressively more resources on failure
    errorStrategy = { task.exitStatus in [104, 137, 139, 143] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
}
